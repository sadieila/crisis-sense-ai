SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional legacy compatibility:
# SUPABASE_SERVICE_KEY=your-supabase-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
INTERNAL_DASHBOARD_API_KEY=your-internal-dashboard-api-key
PORT=3000

# Optional worker tuning
REPORT_PROCESSOR_POLL_MS=5000
REPORT_PROCESSOR_BATCH_SIZE=5
DOCUMENT_EMBEDDING_BATCH_SIZE=20

# Optional seed file path (inside container or host runtime path)
SEED_DOCUMENTS_PATH=

# Smoke test (must match a valid user id in your DB if constraints exist)
SMOKE_USER_ID=
